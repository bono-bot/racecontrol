#!/bin/bash
# Pre-commit hook: Cross-process impact detection + repo guard + co-dev conflict detection
# Warns when staged files affect downstream services via DEPENDENCIES.json

node "$(dirname "$0")/../scripts/check-dependencies.js" 2>/dev/null

# Repo guard: reject comms-link files accidentally staged in racecontrol
BAD=$(git diff --cached --name-only | grep -E "^(bono|james|shared)/" | head -5)
if [ -n "$BAD" ]; then
  echo "ERROR: comms-link files staged in racecontrol repo:"
  echo "$BAD"
  echo "Wrong repo? cd to the correct directory."
  exit 1
fi

# Co-dev conflict guard: BLOCK when committing files modified by the other developer
# within the last 24 hours. Prevents silent overwrites between James and Bono.
# Override with ALLOW_CODEV_OVERWRITE=1 git commit (must be explicit)
STAGED=$(git diff --cached --name-only)
CODEV_CONFLICTS=0
for file in $STAGED; do
  LAST_AUTHOR=$(git log -1 --format='%ae' -- "$file" 2>/dev/null)
  MY_EMAIL=$(git config user.email 2>/dev/null)
  if [ -n "$LAST_AUTHOR" ] && [ -n "$MY_EMAIL" ] && [ "$LAST_AUTHOR" != "$MY_EMAIL" ]; then
    # Check if their change was within 24 hours
    LAST_EPOCH=$(git log -1 --format='%ct' -- "$file" 2>/dev/null)
    NOW_EPOCH=$(date +%s)
    AGE_HOURS=$(( (NOW_EPOCH - LAST_EPOCH) / 3600 ))
    if [ "$AGE_HOURS" -lt 24 ]; then
      LAST_WHEN=$(git log -1 --format='%ar' -- "$file" 2>/dev/null)
      echo "BLOCKED: $file was modified by $LAST_AUTHOR ($LAST_WHEN)"
      echo "  Review: git diff HEAD -- $file"
      echo "  Override: ALLOW_CODEV_OVERWRITE=1 git commit ..."
      CODEV_CONFLICTS=$((CODEV_CONFLICTS + 1))
    fi
  fi
done
if [ "$CODEV_CONFLICTS" -gt 0 ] && [ -z "$ALLOW_CODEV_OVERWRITE" ]; then
  echo ""
  echo "ERROR: $CODEV_CONFLICTS file(s) modified by co-developer in last 24h."
  exit 1
fi

# Warn on .unwrap() in Rust (standing rule)
UNWRAPS=$(git diff --cached -- '*.rs' | grep -n '^\+.*\.unwrap()' | head -5)
if [ -n "$UNWRAPS" ]; then
  echo "WARNING: .unwrap() found in staged Rust code:"
  echo "$UNWRAPS"
  echo "Use ?, .ok(), or match instead."
fi
